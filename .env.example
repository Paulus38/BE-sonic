# Application
NODE_ENV=development
PORT=3001
APP_NAME=Sonic Scribe API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security (generate strong secrets for production)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# PostgreSQL (production) or SQLite (local without Docker)
DB_TYPE=sqlite
DB_SQLITE_PATH=./data/sonic.sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=sonic
DB_PASSWORD=sonic_secure_pass
DB_NAME=sonic_scribe
DB_SYNC=true
DB_LOGGING=false

# Speech / AI
SPEECH_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPGRAM_API_KEY=

# Storage — Firebase project sonic-27ed5 (cloud only for media)
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=sonic-27ed5
FIREBASE_STORAGE_BUCKET=sonic-27ed5.firebasestorage.app
# Download service account JSON from Firebase Console → Project settings → Service accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/sonic-27ed5-firebase-adminsdk.json
# Or paste full JSON (optional alternative to path):
# FIREBASE_SERVICE_ACCOUNT_JSON=
MAX_AUDIO_MB=50
# Legacy local cache dir (not used as primary storage)
UPLOAD_DIR=./uploads

# Rate limit
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
