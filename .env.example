# Application
NODE_ENV=development
PORT=3001
APP_NAME=Sonic Scribe API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://localhost,capacitor://localhost

# Security (generate strong secrets for production)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Prefer short-lived access tokens (e.g. 1h–2h). Avoid multi-day JWTs in production.
JWT_EXPIRES_IN=2h
BCRYPT_ROUNDS=12
# Swagger UI (/docs). Disabled automatically when NODE_ENV=production unless forced.
# SWAGGER_ENABLED=true

# Cloud data (Firestore) + audio (Cloudflare R2 / Vercel Blob)
DB_PROVIDER=firestore
DB_TYPE=firestore
DB_SQLITE_PATH=./data/sonic.sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=sonic
DB_PASSWORD=
DB_NAME=sonic_scribe
DB_SYNC=false
DB_LOGGING=false

# Speech / AI — see be/AI_SETUP.md
# Cần cho: (1) STT Gemini, (2) tóm tắt bản ghi, (3) dịch EN→VI fallback.
# Không cần cho: Free Dictionary, nghĩa VI free, Web Speech, auth/storage.
# gemini | deepgram | auto (pick ready provider with lowest latency; failover on start fail)
SPEECH_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
DEEPGRAM_API_KEY=

# RBAC — emails here become admin ONLY on first register (or legacy users with no role).
# Leave empty in production. Demoting an admin via API will stick (no re-promotion).
ADMIN_EMAILS=

MAX_AUDIO_MB=200
UPLOAD_DIR=./uploads
STORAGE_ALLOW_LOCAL_FALLBACK=false
# Quota hiển thị trên sidebar (GB). Vercel Blob hobby thường ~1GB.
STORAGE_QUOTA_GB=1
# Soft quota hiển thị token AI (không phải rate-limit Google thật).
# Free Flash thường ~1–1.5M token/ngày tùy project — chỉnh theo nhu cầu.
AI_TOKEN_QUOTA=1500000

# Logging (app stdout JSON on Vercel; audit trail in Firestore)
# error | warn | info | debug — default: debug (dev) / info (production)
LOG_LEVEL=debug
# Log mỗi HTTP request (method/path/status). Set false để tắt.
LOG_HTTP=true

# Vercel Blob (primary) — see be/VERCEL_BLOB_SETUP.md
BLOB_READ_WRITE_TOKEN=
# public | private — phải khớp Access của Blob store trên Vercel
# Store hiện tại là Public → dùng public. Private store mới thì mới set private.
BLOB_ACCESS=public

# Firestore / Firebase Admin (metadata + Auth SDK)
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=sonic-27ed5
FIREBASE_STORAGE_BUCKET=sonic-27ed5.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/sonic-27ed5-firebase-adminsdk.json

# Rate limit (HTTP)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Live WebSocket soft limits (per connection)
LIVE_AUDIO_CHUNK_PER_SEC=40
LIVE_UTTERANCE_PER_SEC=20
LIVE_SESSION_START_PER_MIN=10
