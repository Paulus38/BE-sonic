# Application
NODE_ENV=development
PORT=3001
APP_NAME=Sonic Scribe API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security (generate strong secrets for production)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Cloud data (Firestore) + audio (Cloudflare R2)
DB_PROVIDER=firestore
DB_TYPE=firestore
DB_SQLITE_PATH=./data/sonic.sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=sonic
DB_PASSWORD=sonic_secure_pass
DB_NAME=sonic_scribe
DB_SYNC=false
DB_LOGGING=false

# Speech / AI — see be/AI_SETUP.md
# Cần cho: (1) STT Gemini, (2) tóm tắt bản ghi, (3) dịch EN→VI fallback.
# Không cần cho: Free Dictionary, nghĩa VI free, Web Speech, auth/storage.
SPEECH_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPGRAM_API_KEY=

# RBAC — emails in this list become admin on register/login
ADMIN_EMAILS=demo@sonic.app

MAX_AUDIO_MB=50
UPLOAD_DIR=./uploads
STORAGE_ALLOW_LOCAL_FALLBACK=true
# Quota hiển thị trên sidebar (GB). Vercel Blob hobby thường ~1GB.
STORAGE_QUOTA_GB=1

# Vercel Blob (primary) — see be/VERCEL_BLOB_SETUP.md
BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS=public


# Firestore / Firebase Admin (metadata + Auth SDK)
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=sonic-27ed5
FIREBASE_STORAGE_BUCKET=sonic-27ed5.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/sonic-27ed5-firebase-adminsdk.json

# Rate limit
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
